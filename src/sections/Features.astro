---
import Icon from "@components/Icon.astro";
import Reveal from "@components/Reveal.astro";
import { FEATURES } from "@data/content";
---
<section id="recursos" class="section-dark py-20 md:py-28 features-bg">
  <div class="container-tight">
    <Reveal class="max-w-2xl">
      <span class="eyebrow">O pacote completo</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">
        Tudo que sua barbearia precisa<br class="hidden md:block" />
        pra não perder mais nenhum horário.
      </h2>
      <p class="mt-4 text-[var(--cor-texto-secundario)]">
        Nada de planilha, caderninho ou cinco abas abertas no navegador.
        A Skedoole junta agenda, fila, pagamento e relatório no mesmo lugar.
      </p>
    </Reveal>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f, i) => (
        <Reveal delay={(i % 3) * 80} class="card card-hover p-6 md:p-7">
          <div class="feature-icon">
            <Icon name={f.icon} size={22} />
          </div>
          <h3 class="mt-5 text-lg font-bold">{f.title}</h3>
          <p class="mt-2 text-sm text-[var(--cor-texto-secundario)]">{f.desc}</p>
          <ul class="mt-4 space-y-2">
            {f.bullets.map((b) => (
              <li class="feature-bullet">
                <Icon name="check" size={14} />
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </Reveal>
      ))}
    </div>
  </div>
</section>

<style>
  .features-bg {
    position: relative;
    overflow: hidden;
  }
  .features-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(800px 600px at 20% 30%, rgb(var(--cor-primaria-rgb) / 0.08), transparent 60%),
      radial-gradient(600px 500px at 80% 70%, rgb(var(--cor-primaria-rgb) / 0.06), transparent 60%),
      radial-gradient(500px 400px at 50% 50%, rgb(var(--cor-primaria-rgb) / 0.04), transparent 70%);
    animation: meshMove 20s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes meshMove {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 30px) scale(0.95); }
  }
  .features-bg > .container-tight {
    position: relative;
    z-index: 1;
  }
  .feature-highlight {
    border-color: rgb(var(--cor-primaria-rgb) / 0.4);
    background:
      linear-gradient(180deg, rgb(var(--cor-primaria-rgb) / 0.1), transparent 50%),
      var(--cor-cards);
  }
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px; height: 48px;
    border-radius: var(--radius-md);
    background: var(--cor-primaria-soft);
    color: var(--cor-primaria);
    border: 1.5px solid rgb(var(--cor-primaria-rgb) / 0.25);
    box-shadow: 0 0 20px rgb(var(--cor-primaria-rgb) / 0.15);
    transition: all 0.3s ease;
  }
  .card-hover:hover .feature-icon {
    box-shadow: 0 0 30px rgb(var(--cor-primaria-rgb) / 0.3);
    border-color: rgb(var(--cor-primaria-rgb) / 0.5);
    transform: scale(1.05);
  }
  .feature-bullet {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.86rem; color: var(--cor-texto-secundario);
  }
  .feature-bullet :global(svg) { color: var(--cor-primaria); }
</style>
