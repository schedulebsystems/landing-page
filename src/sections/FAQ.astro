---
import Icon from "@components/Icon.astro";
import Reveal from "@components/Reveal.astro";
import { FAQS } from "@data/content";
---
<section id="faq" class="py-24 md:py-32" style="background: var(--cor-fundo-elevado);">
  <div class="container-tight faq-cols">
    <Reveal class="faq-intro">
      <span class="eyebrow">Dúvidas</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">
        Perguntas que todo dono faz<br />antes de começar.
      </h2>
      <p class="mt-4 text-[var(--cor-texto-secundario)]">
        Se ficar alguma, chama a gente no WhatsApp — respondemos em minutos.
      </p>
    </Reveal>

    <div class="faq-list">
      {FAQS.map((f, i) => (
        <Reveal as="details" delay={(i % 4) * 60} class="faq-item">
          <summary>
            <span>{f.q}</span>
            <Icon name="chevron-down" size={20} class="faq-chev" />
          </summary>
          <div class="faq-a">{f.a}</div>
        </Reveal>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-cols {
    display: grid; gap: 32px 48px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 880px) {
    .faq-cols {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
  .faq-intro { position: sticky; top: 96px; align-self: start; }
  .faq-list { display: flex; flex-direction: column; gap: 10px; }
  .faq-item {
    background: var(--cor-cards);
    border: 1px solid var(--cor-borda-geral);
    border-radius: var(--radius-md);
    padding: 0;
    overflow: hidden;
  }
  .faq-item[open] {
    background: var(--cor-cards-hover);
    border-color: var(--cor-borda-hover);
  }
  .faq-item summary {
    list-style: none; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
    padding: 18px 20px;
    font-weight: 600;
    color: var(--cor-texto-primario);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chev { transition: transform 0.25s ease; color: var(--cor-subtitulos); flex-shrink: 0; }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }
  .faq-a {
    padding: 0 20px 18px;
    color: var(--cor-texto-secundario);
    font-size: 0.95rem; line-height: 1.6;
  }
</style>
