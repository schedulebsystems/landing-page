---
import Icon from "@components/Icon.astro";
import Reveal from "@components/Reveal.astro";
import { PLANS } from "@data/content";
import { SITE } from "@config/site";

const app = `${SITE.appUrl}/agendar`;
const wpp = SITE.whatsapp;

const fmtBRL = (n: number) =>
  n === 0
    ? "R$ 0"
    : new Intl.NumberFormat("pt-BR", {
        style: "currency",
        currency: "BRL",
        maximumFractionDigits: 0,
      }).format(n);
---
<section id="precos" class="py-24 md:py-32">
  <div class="container-tight">
    <Reveal class="text-center mx-auto max-w-2xl">
      <span class="eyebrow justify-center">Investimento</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">
        Preço direto. Sem pegadinha, sem surpresa.
      </h2>
      <p class="mt-4 text-[var(--cor-texto-secundario)]">
        Teste grátis por 14 dias. Sem cartão. Cancele em 1 toque.
      </p>
    </Reveal>

    <div class="prices-toggle-wrap mt-8">
      <div class="prices-toggle" role="radiogroup" aria-label="Ciclo de cobrança">
        <button type="button" data-cycle="monthly" class="is-active" role="radio" aria-checked="true">Mensal</button>
        <button type="button" data-cycle="annual" role="radio" aria-checked="false">
          Anual <span class="save">-8%</span>
        </button>
      </div>
    </div>

    <div class="prices-grid mt-10">
      {PLANS.map((p, i) => (
        <Reveal
          delay={i * 100}
          class={`plan ${p.featured ? "plan-featured" : ""}`}
          data-plan={p.name}
        >
          {p.badge && <div class="plan-badge">{p.badge}</div>}
          <h3 class="plan-name">{p.name}</h3>
          <p class="plan-tagline">{p.tagline}</p>
          <div class="plan-price">
            <span data-monthly>{fmtBRL(p.monthly)}</span>
            <span data-annual hidden>{fmtBRL(p.annual)}</span>
            <span class="plan-cycle">/mês</span>
          </div>
          <a
            href={p.name === "Estúdio" ? wpp : app}
            class={`btn mt-5 w-full ${p.featured ? "btn-primary" : "btn-ghost"}`}
            target={p.name === "Estúdio" ? "_blank" : undefined}
            rel={p.name === "Estúdio" ? "noopener" : undefined}
            data-cta={`plan-${p.name.toLowerCase()}`}
          >
            {p.cta}
          </a>
          <ul class="plan-features mt-6">
            {p.features.map((f) => (
              <li>
                <Icon name="check" size={16} />
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </Reveal>
      ))}
    </div>
    <p class="prices-foot mt-8 text-center text-sm text-[var(--cor-subtitulos)]">
      Precificação em BRL. Sem taxa de adesão. Cancele quando quiser.
    </p>
  </div>
</section>

<style>
  .prices-toggle-wrap { display: flex; justify-content: center; }
  .prices-toggle {
    display: inline-flex;
    background: var(--cor-fundo-elevado);
    border: 1px solid var(--cor-borda-geral);
    padding: 4px;
    border-radius: 9999px;
    gap: 2px;
  }
  .prices-toggle button {
    border: 0; cursor: pointer;
    padding: 8px 18px;
    border-radius: 9999px;
    font-size: 0.85rem; font-weight: 600;
    background: transparent;
    color: var(--cor-texto-secundario);
    transition: background 0.2s ease, color 0.2s ease;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .prices-toggle button.is-active {
    background: var(--cor-cards-hover);
    color: var(--cor-texto-primario);
  }
  .prices-toggle .save {
    font-size: 0.7rem; font-weight: 700;
    background: var(--cor-primaria);
    color: #fff;
    padding: 2px 6px; border-radius: 9999px;
  }
  .prices-toggle button.is-active .save {
    background: var(--cor-primaria); color: #fff;
  }
  .prices-grid {
    display: grid; gap: 16px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .prices-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  .plan {
    position: relative;
    padding: 24px;
    background: var(--cor-cards);
    border: 1px solid var(--cor-borda-geral);
    border-radius: var(--radius-lg);
    box-shadow: var(--sombra-card);
    display: flex; flex-direction: column;
  }
  .plan-featured {
    border-color: var(--cor-primaria);
    box-shadow:
      0 0 0 1px var(--cor-primaria),
      0 30px 60px -30px rgb(var(--cor-primaria-rgb) / 0.3);
    transform: translateY(-8px);
  }
  @media (max-width: 720px) { .plan-featured { transform: none; } }
  .plan-badge {
    position: absolute;
    top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--cor-primaria);
    color: #fff;
    font-size: 0.7rem; font-weight: 700;
    padding: 4px 10px; border-radius: 9999px;
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .plan-name { font-size: 1.25rem; font-weight: 700; color: var(--cor-texto-primario); }
  .plan-tagline { font-size: 0.85rem; color: var(--cor-subtitulos); margin-top: 2px; }
  .plan-price { margin-top: 14px; display: flex; align-items: baseline; gap: 4px; }
  .plan-price :strong, .plan-price span:not(.plan-cycle) {
    font-size: 2rem; font-weight: 700; letter-spacing: -0.02em;
    color: var(--cor-texto-primario);
  }
  .plan-cycle { font-size: 0.85rem; color: var(--cor-subtitulos); margin-left: 4px; }
  .plan-features { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .plan-features li {
    display: flex; align-items: flex-start; gap: 8px;
    font-size: 0.88rem; color: var(--cor-texto-secundario);
  }
  .plan-features :global(svg) { color: var(--cor-status-ok); flex-shrink: 0; margin-top: 2px; }
</style>

<script>
  const setup = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".prices-toggle button");
    if (buttons.length === 0) return;
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cycle = btn.dataset.cycle;
        buttons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("is-active", active);
          b.setAttribute("aria-checked", String(active));
        });
        document.querySelectorAll<HTMLElement>("[data-plan]").forEach((plan) => {
          const m = plan.querySelector<HTMLElement>("[data-monthly]");
          const a = plan.querySelector<HTMLElement>("[data-annual]");
          if (!m || !a) return;
          m.hidden = cycle !== "monthly";
          a.hidden = cycle !== "annual";
        });
      });
    });
  };
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
