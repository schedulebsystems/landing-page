---
import Reveal from "@components/Reveal.astro";
import { TESTIMONIALS } from "@data/content";

function renderStars(n: number) {
  return Array.from({ length: 5 }, (_, i) =>
    i < n ? `<span class="star is-on">★</span>` : `<span class="star">★</span>`
  ).join("");
}
---
<section id="historias" class="py-24 md:py-32" style="background: var(--cor-fundo-elevado);">
  <div class="container-tight">
    <Reveal class="text-center mx-auto max-w-2xl">
      <span class="eyebrow justify-center">Histórias de quem usa</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">
        Donos de barbearia que pararam de perder horário.
      </h2>
      <p class="mt-4 text-[var(--cor-texto-secundario)]">
        Sem depoimento fajuto. Cada nome abaixo é uma barbearia
        ou salão que trocou o caderninho pela Skedoole.
      </p>
    </Reveal>
  </div>

  <div class="marquee mt-12" aria-label="Depoimentos em rolagem">
    <div class="marquee-track">
      {[...TESTIMONIALS, ...TESTIMONIALS].map((t, i) => (
        <figure class="t-card" style={`--i:${i}`}>
          <div class="t-stars" set:html={renderStars(t.rating)} />
          <blockquote class="t-quote">{t.quote}</blockquote>
          <figcaption class="t-author">
            <span class="t-avatar">{t.initials}</span>
            <span>
              <b>{t.name}</b>
              <small>{t.role} · {t.city}</small>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
  <div class="marquee-mask" aria-hidden="true"></div>
</section>

<style>
  .marquee {
    position: relative;
    overflow: hidden;
    padding-block: 4px;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .marquee-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: marquee 60s linear infinite;
  }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; flex-wrap: wrap; }
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 0.5rem)); }
  }
  .t-card {
    flex: 0 0 auto;
    width: min(80vw, 360px);
    padding: 20px 22px;
    background: var(--cor-cards);
    border: 1px solid var(--cor-borda-geral);
    border-radius: var(--radius-lg);
    box-shadow: var(--sombra-card);
    display: flex; flex-direction: column; gap: 12px;
  }
  .t-stars { display: flex; gap: 2px; font-size: 1rem; line-height: 1; color: var(--cor-borda-geral); }
  .star.is-on { color: var(--cor-primaria); }
  .t-quote {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--cor-texto-primario);
    margin: 0;
  }
  .t-author { display: flex; align-items: center; gap: 10px; }
  .t-avatar {
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--cor-cards-hover);
    color: var(--cor-texto-primario);
    font-weight: 700; font-size: 0.78rem;
    border: 1px solid var(--cor-borda-geral);
  }
  .t-author b { display: block; font-size: 0.85rem; color: var(--cor-texto-primario); }
  .t-author small { font-size: 0.72rem; color: var(--cor-subtitulos); }
</style>
